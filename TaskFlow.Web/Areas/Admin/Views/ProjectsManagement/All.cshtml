@model IEnumerable<ProjectViewModel>
@{
    ViewData["Title"] = "Admin Projects";
}
<h1>Admin - Projects</h1>
<p>This starter admin page is protected by the Administrator role. Extend it with all-project management.</p>
<table class="table">
@foreach (var project in Model)
{
    <tr><td>@project.Name</td><td>@project.OwnerName</td><td>@project.BoardsCount boards</td></tr>
}
</table>
