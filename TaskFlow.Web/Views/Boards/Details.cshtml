@model BoardViewModel
@{
    ViewData["Title"] = Model.Name;
    var tasks = (IEnumerable<TaskViewModel>)ViewBag.Tasks;
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>@Model.Name</h1>
    <a class="btn btn-primary" asp-controller="Tasks" asp-action="Create" asp-route-boardId="@Model.Id">Add Task</a>
</div>
<div class="mb-3">
    <input id="taskSearch" class="form-control" placeholder="Search tasks with AJAX..." />
</div>
<div id="taskResults" class="row">
@foreach (var task in tasks)
{
    <div class="col-md-4 mb-3 task-card">
        <div class="card h-100"><div class="card-body">
            <h5>@task.Title</h5>
            <p>@task.Description</p>
            <span class="badge bg-secondary">@task.Status</span>
            <span class="badge bg-info">@task.Priority</span>
            <div class="mt-3">
                <a class="btn btn-sm btn-outline-primary" asp-controller="Tasks" asp-action="Details" asp-route-id="@task.Id">Details</a>
                <button class="btn btn-sm btn-outline-success" onclick="changeStatus(@task.Id, 'Done')">Mark Done</button>
            </div>
        </div></div>
    </div>
}
</div>
@section Scripts {
<script src="~/js/tasks.js"></script>
}
