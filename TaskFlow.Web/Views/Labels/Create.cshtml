@model LabelInputModel
@{
    ViewData["Title"] = "Create Label";
}
<h1>Create Label</h1>
<form asp-action="Create" method="post">
    <div class="mb-3"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger"></span></div>
    <div class="mb-3"><label asp-for="Color" class="form-label"></label><input asp-for="Color" class="form-control" /><span asp-validation-for="Color" class="text-danger"></span></div>
    <button class="btn btn-primary">Create</button>
</form>
