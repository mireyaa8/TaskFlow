@model IEnumerable<TaskViewModel>
@{
    ViewData["Title"] = "My Tasks";
}
<h1>My Tasks</h1>
<table class="table table-striped">
<thead><tr><th>Title</th><th>Status</th><th>Priority</th><th></th></tr></thead>
<tbody>
@foreach (var task in Model)
{
    <tr>
        <td>@task.Title</td>
        <td>@task.Status</td>
        <td>@task.Priority</td>
        <td><a asp-action="Details" asp-route-id="@task.Id">Details</a></td>
    </tr>
}
</tbody>
</table>
